@page "/"
@rendermode InteractiveServer
@inject ICatalogueRepository Repository
@inject IConfiguration Configuration

<PageTitle>Dashboard &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<h1 class="mb-4">Dashboard</h1>

@if (_summary is null)
{
    <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
}
else
{
    <h2 class="h5 mb-3">Source Databases</h2>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <div class="card-title h5">Servers</div>
                    <div class="display-5">@_summary.TotalServers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success">
                <div class="card-body">
                    <div class="card-title h5">Databases</div>
                    <div class="display-5">@_summary.TotalDatabases</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info">
                <div class="card-body">
                    <div class="card-title h5">Tables</div>
                    <div class="display-5">@_summary.TotalTables</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-secondary">
                <div class="card-body">
                    <div class="card-title h5">Columns</div>
                    <div class="display-5">@_summary.TotalColumns</div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5 mb-3">Migrations</h2>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <div class="card-title">In-Scope Relational (R)</div>
                    <div class="fs-2 text-primary">@_summary.InScopeRelationalColumns</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body">
                    <div class="card-title">In-Scope Document (D)</div>
                    <div class="fs-2 text-warning">@_summary.InScopeDocumentColumns</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body">
                    <div class="card-title">Selected for Load</div>
                    <div class="fs-2 text-success">@_summary.SelectedForLoadColumns</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body">
                    <div class="card-title">Unreviewed</div>
                    <div class="fs-2 text-danger">@_summary.UnreviewedColumns</div>
                </div>
            </div>
        </div>
    </div>

    @if (_summary.LastModifiedAt.HasValue)
    {
        <div class="alert alert-light border">
            Last change: <strong>@_summary.LastModifiedBy</strong>
            on <strong>@_summary.LastModifiedAt.Value.ToString("dd MMM yyyy HH:mm")</strong> UTC
        </div>
    }

    <h2 class="h5 mb-3 mt-4">Schema Browser</h2>
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-info h-100">
                <div class="card-body">
                    <h6 class="card-title">Browse Database Schema</h6>
                    <p class="card-text text-muted small">
                        Explore tables, views, stored procedures, functions, and triggers
                        with full SQL bodies for each database.
                    </p>
                    <a href="/servers" class="btn btn-sm btn-outline-info">
                        &#128269; Open Schema Browser
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-secondary h-100">
                <div class="card-body">
                    <h6 class="card-title">Import DACPAC Schema</h6>
                    <p class="card-text text-muted small">
                        Import one or more <code>.dacpac</code> files to populate
                        full schema metadata including SQL bodies.
                    </p>
                    <a href="/import/dacpac-folder" class="btn btn-sm btn-outline-secondary me-2">
                        &#128193; Import Folder
                    </a>
                    <a href="/import/dacpac" class="btn btn-sm btn-outline-secondary">
                        &#128230; Import Single
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CatalogueSummaryDto? _summary;

    protected override async Task OnInitializedAsync()
        => _summary = await Repository.GetCatalogueSummaryAsync();
}
