@page "/import/dacpac-folder"
@rendermode InteractiveServer
@using Dacpac.Management.Models
@using Dacpac.Management.Services
@inject DacpacSchemaImportService SchemaImporter
@inject BlazorGenerationLogger Logger
@inject NotificationService Notify
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>Import DACPAC Folder &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<h1>Import DACPAC Folder</h1>
<p class="text-muted">
    Point to a folder containing one or more <code>.dacpac</code> files. Each file is imported
    as a separate database with full schema detail — tables, columns (with type metadata),
    indexes, foreign keys, constraints, views, stored procedures, functions, and triggers.
</p>
<div class="alert alert-info d-flex align-items-start gap-2 py-2" role="alert">
    <span class="oi oi-info" aria-hidden="true"></span>
    <div>
        <strong>File naming requirement:</strong> Each <code>.dacpac</code> file must be named using the pattern
        <code>&lt;server-name&gt;_&lt;database-name&gt;.dacpac</code> (e.g. <code>MYSERVER_MyDatabase.dacpac</code>).
        The server name and database name are derived automatically from the file name — no manual entry is required.
    </div>
</div>

@if (_results.Count > 0)
{
    <div class="mb-4">
        @foreach (var r in _results)
        {
            <div class="alert @(r.Success ? "alert-success" : "alert-danger") mb-2">
                <strong>@r.ServerName \ @r.DatabaseName</strong>
                @if (!r.Success) { <span class="text-danger ms-2">— failed</span> }
                <div class="row g-2 mt-1 flex-wrap">
                    <div class="col-auto"><span class="badge bg-secondary">Tables: @r.TablesProcessed</span></div>
                    <div class="col-auto"><span class="badge bg-primary">Cols updated: @r.ColumnsUpdated</span></div>
                    <div class="col-auto"><span class="badge bg-info text-dark">Cols created: @r.ColumnsCreated</span></div>
                    <div class="col-auto"><span class="badge bg-success">Views: @r.ViewsImported</span></div>
                    <div class="col-auto"><span class="badge bg-warning text-dark">Procs: @r.StoredProceduresImported</span></div>
                    <div class="col-auto"><span class="badge bg-warning text-dark">Functions: @r.FunctionsImported</span></div>
                    <div class="col-auto"><span class="badge bg-secondary">Indexes: @r.IndexesImported</span></div>
                    <div class="col-auto"><span class="badge bg-secondary">FKs: @r.ForeignKeysImported</span></div>
                    <div class="col-auto"><span class="badge bg-secondary">Triggers: @r.TriggersImported</span></div>
                </div>
                @foreach (var err in r.Errors)
                {
                    <div class="text-danger mt-1 small">@err</div>
                }
            </div>
        }
    </div>
}

<div class="row g-3" style="max-width:700px">
    <div class="col-12">
        <label class="form-label">DACPAC Folder Path</label>
        <input class="form-control" @bind="_folderPath"
               placeholder='e.g. C:\Dacpacs or /home/user/dacpacs'
               disabled="@_running" />
        <div class="form-text">All <code>.dacpac</code> files in this folder will be imported.</div>
    </div>
    <div class="col-12">
        <button class="btn btn-primary" @onclick="RunImport" disabled="@(!CanImport)">
            @if (_running)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                <span>Importing&hellip;</span>
            }
            else
            {
                <span>&#8599; Import Folder</span>
            }
        </button>
    </div>
</div>

@if (_logLines.Count > 0 || _running)
{
    <div class="card mt-4">
        <div class="card-header fw-semibold d-flex justify-content-between">
            <span>Progress</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _logLines.Clear()">Clear</button>
        </div>
        <div class="card-body p-0">
            <div style="font-family:monospace;font-size:.82rem;max-height:400px;overflow-y:auto;padding:.75rem;background:#000;color:#e8e8e8;">
                @foreach (var (level, msg) in _logLines)
                {
                    <div class="@LogClass(level)">@msg</div>
                }
                @if (_running)
                {
                    <div class="text-muted fst-italic">Running&hellip;</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private string _folderPath = string.Empty;
    private bool _running;
    private readonly List<DacpacImportResult> _results = new();
    private readonly List<(string Level, string Message)> _logLines = new();

    private bool CanImport =>
        !_running &&
        !string.IsNullOrWhiteSpace(_folderPath);

    protected override void OnInitialized() => Logger.OnLog += HandleLog;

    private async Task RunImport()
    {
        if (!CanImport) return;

        _results.Clear();
        _logLines.Clear();
        _running = true;
        StateHasChanged();

        try
        {
            var folderResults = await Task.Run(() =>
                SchemaImporter.ImportDacpacFolderAsync(_folderPath.Trim()));

            _results.AddRange(folderResults);

            var successCount = _results.Count(r => r.Success);
            if (successCount == _results.Count && _results.Count > 0)
                Notify.Success($"Imported {successCount} database(s) successfully.");
            else if (successCount > 0)
                Notify.Warning($"Imported {successCount} of {_results.Count} database(s) — some had errors.");
            else if (_results.Count == 0)
                Notify.Warning("No .dacpac files found in the specified folder.");
            else
                Notify.Error("All imports failed — see details.");
        }
        catch (Exception ex)
        {
            Notify.Error($"Unexpected error: {ex.Message}");
            _logLines.Add(("error", ex.ToString()));
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private void HandleLog(string level, string message)
    {
        InvokeAsync(() =>
        {
            _logLines.Add((level, message));
            StateHasChanged();
        });
    }

    private static string LogClass(string level) => level switch
    {
        "error"    => "text-danger",
        "warning"  => "text-warning",
        "progress" => "text-info",
        _          => "text-light"
    };

    public void Dispose() => Logger.OnLog -= HandleLog;
}
