@page "/generation/ef"
@rendermode InteractiveServer
@using DacpacEntityGenerator.Core.Models
@using DacpacEntityGenerator.Core.Services
@using Catalogue.Core.Abstractions
@using Dacpac.Management.Models
@using Dacpac.Management.Services
@inject BlazorGenerationLogger Logger
@inject GenerationOrchestrator Orchestrator
@inject CatalogueGenerationOrchestrator DbOrchestrator
@inject CatalogueDbSchemaDataSource DataSource
@inject ICatalogueRepository Repo
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>EF Generation &mdash; @Configuration["AppTitle"]</PageTitle>

<h1>EF Entity Generation</h1>
<p class="text-muted">
    Generate EF Core entity classes from CatalogueDb (Database-sourced) or from Excel + DACPAC files (File-sourced).
</p>

@* ── Mode tabs ────────────────────────────────────────────────────────────────── *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_mode == GenMode.DatabaseSourced ? "active" : "")"
                @onclick="() => SetMode(GenMode.DatabaseSourced)"
                disabled="@_running">
            &#128209;&nbsp;Database-sourced
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_mode == GenMode.FileSourced ? "active" : "")"
                @onclick="() => SetMode(GenMode.FileSourced)"
                disabled="@_running">
            &#128196;&nbsp;File-sourced (Excel + DACPAC)
        </button>
    </li>
</ul>

@if (_mode == GenMode.DatabaseSourced)
{
    @* ── Database-sourced: source selection ──────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Source Database</div>
        <div class="card-body row g-3" style="max-width:900px">
            <div class="col-12">
                <label class="form-label">Select Database</label>
                @if (_databases.Count == 0)
                {
                    <div class="alert alert-warning mb-0">
                        No databases found in CatalogueDb. Import data first via the Import pages.
                    </div>
                }
                else
                {
                    <select class="form-select font-monospace"
                            @bind="_selectedDatabaseId"
                            disabled="@_running">
                        <option value="0">-- select a database --</option>
                        @foreach (var db in _databases)
                        {
                            <option value="@db.DatabaseId">
                                [@db.ServerName].[@db.DatabaseName]&nbsp;&nbsp;(@db.SelectedForLoadCount selected for load)
                            </option>
                        }
                    </select>
                }
                <div class="form-text">
                    Columns with <em>IsSelectedForLoad = true</em> and
                    <em>PersistenceType ≠ 'D'</em> are included in generation.
                </div>
            </div>
        </div>
    </div>

    @* ── Database-sourced: output locations ────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Output Locations</div>
        <div class="card-body row g-3" style="max-width:900px">
            <div class="col-12">
                <label class="form-label">Entity Output Folder</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/output/entities/"
                       @bind="_entityOutputPath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the folder where generated entity .cs files will be written.</div>
            </div>
            <div class="col-12">
                <label class="form-label">DbContext File</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/MyDbContext.cs"
                       @bind="_dbContextFilePath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the .cs file where the DbContext will be written (will be overwritten).</div>
            </div>
        </div>
    </div>
}
else
{
    @* ── File-sourced: input files ───────────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Input Files</div>
        <div class="card-body row g-3" style="max-width:900px">
            <div class="col-12">
                <label class="form-label">Excel Mapping File</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/mapping.xlsx"
                       @bind="_excelFilePath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the .xlsx mapping file.</div>
            </div>
            <div class="col-12">
                <label class="form-label">DACPAC Files Folder</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/dacpacs/"
                       @bind="_dacpacFolderPath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the folder containing .dacpac files.</div>
            </div>
        </div>
    </div>

    @* ── File-sourced: output locations ─────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Output Locations</div>
        <div class="card-body row g-3" style="max-width:900px">
            <div class="col-12">
                <label class="form-label">Entity Output Folder</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/output/entities/"
                       @bind="_entityOutputPath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the folder where generated entity .cs files will be written.</div>
            </div>
            <div class="col-12">
                <label class="form-label">DbContext File</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/MyDbContext.cs"
                       @bind="_dbContextFilePath" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Full path to the .cs file where the DbContext will be written (will be overwritten).</div>
            </div>
        </div>
    </div>
}

@* ── Validation errors ────────────────────────────────────────────────────── *@
@if (_validationErrors.Count > 0)
{
    <div class="alert alert-warning mb-3">
        <ul class="mb-0">
            @foreach (var err in _validationErrors)
            {
                <li>@err</li>
            }
        </ul>
    </div>
}

@* ── Generate ─────────────────────────────────────────────────────────── *@
<div class="mb-4">
    <button class="btn btn-primary btn-lg"
            @onclick="RunGeneration"
            disabled="@(!CanGenerate)">
        @if (_running)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>Generating&hellip;</span>
        }
        else
        {
            <span>&#9881; Generate</span>
        }
    </button>
    @if (_running)
    {
        <button class="btn btn-outline-danger ms-2" @onclick="Cancel">Cancel</button>
    }
</div>

@* ── Progress Log ─────────────────────────────────────────────────────── *@
@if (_logLines.Count > 0 || _running)
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-flex justify-content-between">
            <span>Progress Log</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLog">Clear</button>
        </div>
        <div class="card-body p-0">
            <div id="logContainer"
                 style="font-family:monospace;font-size:.82rem;max-height:400px;overflow-y:auto;padding:.75rem;background:#000;color:#e8e8e8;">
                @foreach (var (level, message) in _logLines)
                {
                    <div class="@LogLineClass(level)">@message</div>
                }
                @if (_running)
                {
                    <div class="text-muted fst-italic">Running&hellip;</div>
                }
            </div>
        </div>
    </div>
}

@* ── Result ───────────────────────────────────────────────────────────── *@
@if (_result is not null)
{
    <div class="alert @(_result.Success ? "alert-success" : "alert-danger") mb-4">
        @if (_result.Success)
        {
            <strong>Generation complete!</strong>
        }
        else
        {
            <strong>Generation finished with errors.</strong>
        }
        <div class="row g-3 mt-1">
            <div class="col-auto"><span class="badge bg-success fs-6">Entities: @_result.EntitiesGenerated</span></div>
            <div class="col-auto"><span class="badge bg-info fs-6">Views: @_result.ViewsGenerated</span></div>
            <div class="col-auto"><span class="badge bg-warning text-dark fs-6">Skipped: @_result.TablesSkipped</span></div>
            <div class="col-auto"><span class="badge bg-danger fs-6">Errors: @_result.ErrorsEncountered</span></div>
        </div>
        @if (_result.Errors.Count > 0)
        {
            <ul class="mt-2 mb-0">
                @foreach (var e in _result.Errors)
                {
                    <li>@e</li>
                }
            </ul>
        }
    </div>

    @* ── Discovery Reports ──────────────────────────────────────────── *@
    @if (_result.DiscoveryReports.Count > 0)
    {
        <h4>Discovery Reports</h4>
        <p class="text-muted small">
            Elements discovered in the DACPAC(s) that may require manual migration consideration.
        </p>
        @foreach (var report in _result.DiscoveryReports)
        {
            <DiscoveryReportPanel Report="@report" />
        }
    }
}

@code {
    // ── Generation mode ───────────────────────────────────────────────────────
    private enum GenMode { DatabaseSourced, FileSourced }
    private GenMode _mode = GenMode.DatabaseSourced;

    // ── Path inputs (shared + file-sourced) ───────────────────────────────────
    private string _excelFilePath     = string.Empty;
    private string _dacpacFolderPath  = string.Empty;
    private string _entityOutputPath  = string.Empty;
    private string _dbContextFilePath = string.Empty;

    // ── Database-sourced inputs ───────────────────────────────────────────────
    private IReadOnlyList<SourceDatabaseInfo> _databases = Array.Empty<SourceDatabaseInfo>();
    private int _selectedDatabaseId;

    // ── Run state ─────────────────────────────────────────────────────────────
    private bool _running;
    private CancellationTokenSource? _cts;
    private GenerationResult? _result;
    private readonly List<LogEntry> _logLines        = new();
    private readonly List<string>   _validationErrors = new();
    private record LogEntry(string Level, string Message);

    // ── Temp directory ────────────────────────────────────────────────────────
    private string? _tempDir;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        Logger.OnLog += HandleLog;
        _databases = await Repo.GetInScopeDatabasesAsync();
    }

    // ── Mode toggle ───────────────────────────────────────────────────────────
    private void SetMode(GenMode mode)
    {
        if (!_running) _mode = mode;
    }

    // ── CanGenerate ───────────────────────────────────────────────────────────
    private bool CanGenerate => !_running && (
        _mode == GenMode.DatabaseSourced
            ? _selectedDatabaseId > 0
              && !string.IsNullOrWhiteSpace(_entityOutputPath)
              && !string.IsNullOrWhiteSpace(_dbContextFilePath)
            : !string.IsNullOrWhiteSpace(_excelFilePath)
              && !string.IsNullOrWhiteSpace(_dacpacFolderPath)
              && !string.IsNullOrWhiteSpace(_entityOutputPath)
              && !string.IsNullOrWhiteSpace(_dbContextFilePath));

    // ── Generation dispatch ───────────────────────────────────────────────────
    private async Task RunGeneration()
    {
        if (!CanGenerate) return;

        // Validation
        _validationErrors.Clear();
        if (_mode == GenMode.FileSourced)
        {
            if (!File.Exists(_excelFilePath.Trim()))
                _validationErrors.Add($"Excel file not found: {_excelFilePath.Trim()}");
            if (!Directory.Exists(_dacpacFolderPath.Trim()))
                _validationErrors.Add($"DACPAC folder not found: {_dacpacFolderPath.Trim()}");
        }
        if (!Directory.Exists(_entityOutputPath.Trim()))
            _validationErrors.Add($"Entity output folder not found: {_entityOutputPath.Trim()}");

        if (_validationErrors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        _result  = null;
        _logLines.Clear();
        _running = true;
        _cts     = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            if (_mode == GenMode.DatabaseSourced)
                await RunDatabaseSourcedAsync();
            else
                await RunFileSourcedAsync();
        }
        catch (OperationCanceledException)
        {
            _logLines.Add(new LogEntry("warning", "Generation cancelled."));
        }
        catch (Exception ex)
        {
            _logLines.Add(new LogEntry("error", $"Unexpected error: {ex.Message}"));
        }
        finally
        {
            _running = false;
            CleanupTemp();
            StateHasChanged();
        }
    }

    // ── Database-sourced pipeline ─────────────────────────────────────────────
    private async Task RunDatabaseSourcedAsync()
    {
        var entityOutput = _entityOutputPath.Trim();
        var dbContextOut = _dbContextFilePath.Trim();

        _tempDir = Path.Combine(Path.GetTempPath(), "efgen_db_" + Guid.NewGuid().ToString("N"));
        var tempOutput = Path.Combine(_tempDir, "_output");
        Directory.CreateDirectory(tempOutput);

        // Configure the CatalogueDb data source for the selected database
        DataSource.DatabaseId = _selectedDatabaseId;

        _result = await DbOrchestrator.RunAsync(DataSource, tempOutput);

        if (_result.Success && (_result.EntitiesGenerated > 0 || _result.ViewsGenerated > 0))
            CopyOutputFiles(tempOutput, entityOutput, dbContextOut);
    }

    // ── File-sourced pipeline ─────────────────────────────────────────────────
    private async Task RunFileSourcedAsync()
    {
        var excelPath    = _excelFilePath.Trim();
        var dacpacFolder = _dacpacFolderPath.Trim();
        var entityOutput = _entityOutputPath.Trim();
        var dbContextOut = _dbContextFilePath.Trim();

        _tempDir = Path.Combine(Path.GetTempPath(), "efgen_" + Guid.NewGuid().ToString("N"));
        var tempInput  = Path.Combine(_tempDir, "_input");
        var tempOutput = Path.Combine(_tempDir, "_output");
        Directory.CreateDirectory(tempInput);
        Directory.CreateDirectory(tempOutput);

        File.Copy(excelPath, Path.Combine(tempInput, Path.GetFileName(excelPath)), overwrite: true);

        var tempDacpacs = Path.Combine(tempInput, "dacpacs");
        Directory.CreateDirectory(tempDacpacs);
        foreach (var dacpac in Directory.EnumerateFiles(dacpacFolder, "*.dacpac", SearchOption.TopDirectoryOnly))
            File.Copy(dacpac, Path.Combine(tempDacpacs, Path.GetFileName(dacpac)), overwrite: true);

        _result = await Task.Run(() => Orchestrator.Run(tempInput, tempOutput));

        if (_result.Success)
            CopyOutputFiles(tempOutput, entityOutput, dbContextOut);
    }

    // ── Shared output copy ────────────────────────────────────────────────────
    private static void CopyOutputFiles(string tempOutput, string entityOutput, string dbContextOut)
    {
        foreach (var filePath in Directory.EnumerateFiles(tempOutput, "*", SearchOption.AllDirectories))
        {
            var fileName = Path.GetFileName(filePath);

            if (fileName.EndsWith("DbContext.cs", StringComparison.OrdinalIgnoreCase))
            {
                var dbContextDir = Path.GetDirectoryName(dbContextOut);
                if (!string.IsNullOrEmpty(dbContextDir))
                    Directory.CreateDirectory(dbContextDir);
                File.Copy(filePath, dbContextOut, overwrite: true);
            }
            else
            {
                var relativePath = Path.GetRelativePath(tempOutput, filePath);
                var destPath     = Path.Combine(entityOutput, relativePath);
                Directory.CreateDirectory(Path.GetDirectoryName(destPath)!);
                File.Copy(filePath, destPath, overwrite: true);
            }
        }
    }

    private void Cancel() => _cts?.Cancel();

    private void CleanupTemp()
    {
        if (_tempDir is not null && Directory.Exists(_tempDir))
        {
            try { Directory.Delete(_tempDir, recursive: true); } catch { /* best-effort */ }
            _tempDir = null;
        }
    }

    // ── Logger callback ───────────────────────────────────────────────────────
    private void HandleLog(string level, string message)
    {
        InvokeAsync(() =>
        {
            _logLines.Add(new LogEntry(level, message));
            StateHasChanged();
        });
    }

    // ── UI helpers ────────────────────────────────────────────────────────────
    private static string LogLineClass(string level) => level switch
    {
        "error"    => "text-danger",
        "warning"  => "text-warning",
        "progress" => "text-info",
        _          => "text-light",
    };

    private void ClearLog() => _logLines.Clear();

    // ── Cleanup ───────────────────────────────────────────────────────────────
    public void Dispose()
    {
        Logger.OnLog -= HandleLog;
        _cts?.Cancel();
        CleanupTemp();
    }
}
