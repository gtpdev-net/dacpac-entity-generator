@page "/servers/{ServerId:int}/databases/{DatabaseId:int}/tables/new"
@page "/servers/{ServerId:int}/databases/{DatabaseId:int}/tables/{TableId:int}/edit"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject NavigationManager Nav
@inject NotificationService Notify
@inject IConfiguration Configuration

<PageTitle>@(_isNew ? "New Table" : "Edit Table") &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<BreadcrumbNav Items="@_breadcrumbs" />

<EditForm Model="_table" OnValidSubmit="Save" class="row g-3">
    <DataAnnotationsValidator />

    <div class="col-md-2">
        <label class="form-label">Schema</label>
        <InputText @bind-Value="_table.SchemaName" class="form-control" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Table Name</label>
        <InputText @bind-Value="_table.TableName" class="form-control" />
        @if (_nameExists) { <div class="text-danger small">Already exists.</div> }
    </div>
    <div class="col-md-3">
        <label class="form-label">Est. Row Count</label>
        <InputNumber @bind-Value="_table.EstimatedRowCount" class="form-control" />
    </div>
    <div class="col-12">
        <label class="form-label">Notes</label>
        <InputTextArea @bind-Value="_table.Notes" class="form-control" rows="2" />
    </div>
    <div class="col-12">
        <div class="form-check">
            <InputCheckbox @bind-Value="_table.IsActive" class="form-check-input" id="isActive" />
            <label class="form-check-label" for="isActive">Active</label>
        </div>
    </div>

    <!-- Column sub-panel -->
    <div class="col-12">
        <h5 class="mt-2">Columns
            <span class="badge text-bg-secondary fs-6 ms-2">
                @_table.Columns.Count(c => c.IsActive) total &middot;
                @_table.Columns.Count(c => c.IsActive && (c.IsInDaoAnalysis || c.IsAddedByApi)) in scope &middot;
                @_table.Columns.Count(c => c.IsActive && c.IsSelectedForLoad) selected
            </span>
        </h5>

        <!-- Paste area -->
        <div class="input-group mb-2" style="max-width:500px">
            <textarea @bind="_pasteText" class="form-control" rows="2"
                      placeholder="Paste column names (one per line)..."></textarea>
            <button type="button" class="btn btn-outline-secondary" @onclick="PasteColumns">Add</button>
        </div>

        @if (_table.Columns.Any())
        {
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:30px">#</th>
                        <th>Column Name</th>
                        <th style="width:100px">Type</th>
                        <th style="width:80px">DAO</th>
                        <th style="width:80px">API</th>
                        <th style="width:80px">For Load</th>
                        <th style="width:60px">Active</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in _table.Columns.OrderBy(c => c.SortOrder))
                    {
                        <tr>
                            <td>@col.SortOrder</td>
                            <td>@col.ColumnName</td>
                            <td>
                                <select class="form-select form-select-sm"
                                        value="@col.PersistenceType.ToString()"
                                        @onchange="e => col.PersistenceType = string.IsNullOrEmpty(e.Value?.ToString()) ? 'R' : e.Value!.ToString()![0]">
                                    <option value="R">R</option>
                                    <option value="D">D</option>
                                    <option value="B">B</option>
                                </select>
                            </td>
                            <td><input type="checkbox" @bind="col.IsInDaoAnalysis" /></td>
                            <td><input type="checkbox" @bind="col.IsAddedByApi" /></td>
                            <td><input type="checkbox" @bind="col.IsSelectedForLoad" /></td>
                            <td><input type="checkbox" @bind="col.IsActive" /></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        @onclick="() => RemoveColumn(col)">&times;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <!-- Add single column -->
        <div class="input-group mb-2" style="max-width:400px">
            <input class="form-control" placeholder="New column name..." @bind="_newColumnName" />
            <button type="button" class="btn btn-outline-primary" @onclick="AddColumn">Add Column</button>
        </div>
    </div>

    <div class="col-12 mt-2">
        <button type="submit" class="btn btn-primary me-2">Save</button>
        <a href="/servers/@ServerId/databases/@DatabaseId/tables" class="btn btn-secondary">Cancel</a>
    </div>

    @if (!_isNew)
    {
        <AuditFooter CreatedBy="@_table.CreatedBy" CreatedAt="_table.CreatedAt"
                     ModifiedBy="@_table.ModifiedBy" ModifiedAt="_table.ModifiedAt" />
    }
</EditForm>

<!-- ── Schema sections (read-only, sourced from DACPAC import) ───────────── -->
@if (!_isNew && TableId.HasValue)
{
    <hr class="my-4" />
    <h4>Schema Detail
        <small class="text-muted fs-6 ms-2 fw-normal">from DACPAC import</small>
    </h4>

    <!-- Indexes -->
    <div class="mb-3">
        <button class="btn btn-sm btn-outline-secondary mb-2"
                @onclick="ToggleIndexes">
            @(_showIndexes ? "▲" : "▼") Indexes
            @if (_indexes is not null)
            {
                <span class="badge text-bg-secondary ms-1">@_indexes.Count</span>
            }
        </button>
        @if (_showIndexes)
        {
            @if (_indexes is null)
            {
                <div class="spinner-border spinner-border-sm ms-2"></div>
            }
            else if (_indexes.Count == 0)
            {
                <p class="text-muted small">No indexes found.</p>
            }
            else
            {
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>PK</th>
                            <th>Unique</th>
                            <th>Clustered</th>
                            <th>Columns</th>
                            <th>Filter</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ix in _indexes)
                        {
                            <tr>
                                <td><code>@ix.Name</code></td>
                                <td><FlagBadge Value="@ix.IsPrimaryKeyIndex" /></td>
                                <td><FlagBadge Value="@ix.IsUnique" /></td>
                                <td><FlagBadge Value="@ix.IsClustered" /></td>
                                <td>@string.Join(", ", ix.Columns)</td>
                                <td>@ix.FilterDefinition</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

    <!-- Foreign Keys -->
    <div class="mb-3">
        <button class="btn btn-sm btn-outline-secondary mb-2"
                @onclick="ToggleForeignKeys">
            @(_showForeignKeys ? "▲" : "▼") Foreign Keys
            @if (_foreignKeys is not null)
            {
                <span class="badge text-bg-secondary ms-1">@_foreignKeys.Count</span>
            }
        </button>
        @if (_showForeignKeys)
        {
            @if (_foreignKeys is null)
            {
                <div class="spinner-border spinner-border-sm ms-2"></div>
            }
            else if (_foreignKeys.Count == 0)
            {
                <p class="text-muted small">No foreign keys found.</p>
            }
            else
            {
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>To Table</th>
                            <th>Cardinality</th>
                            <th>On Delete</th>
                            <th>Columns</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fk in _foreignKeys)
                        {
                            <tr>
                                <td><code>@fk.Name</code></td>
                                <td><code>[@fk.ToSchema].[@fk.ToTable]</code></td>
                                <td>@fk.Cardinality</td>
                                <td><FlagBadge Value="@fk.OnDeleteCascade" /></td>
                                <td>
                                    @foreach (var col in fk.Columns)
                                    {
                                        <span class="d-block small">@col.FromColumn → @col.ToColumn</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

    <!-- Check Constraints  (loaded inline via EF directly via SourceTable nav) -->
    <div class="mb-3">
        <button class="btn btn-sm btn-outline-secondary mb-2"
                @onclick='() => _showCheckConstraints = !_showCheckConstraints' type="button">
            @(_showCheckConstraints ? "▲" : "▼") Check Constraints
            @if (_table.CheckConstraints is not null)
            {
                <span class="badge text-bg-secondary ms-1">@_table.CheckConstraints.Count</span>
            }
        </button>
        @if (_showCheckConstraints)
        {
            @if (_table.CheckConstraints is null || _table.CheckConstraints.Count == 0)
            {
                <p class="text-muted small">No check constraints found.</p>
            }
            else
            {
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light"><tr><th>Name</th><th>Expression</th></tr></thead>
                    <tbody>
                        @foreach (var cc in _table.CheckConstraints)
                        {
                            <tr>
                                <td><code>@cc.Name</code></td>
                                <td><code>@cc.Expression</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

    <!-- Unique Constraints -->
    <div class="mb-3">
        <button class="btn btn-sm btn-outline-secondary mb-2"
                @onclick='() => _showUniqueConstraints = !_showUniqueConstraints' type="button">
            @(_showUniqueConstraints ? "▲" : "▼") Unique Constraints
            @if (_table.UniqueConstraints is not null)
            {
                <span class="badge text-bg-secondary ms-1">@_table.UniqueConstraints.Count</span>
            }
        </button>
        @if (_showUniqueConstraints)
        {
            @if (_table.UniqueConstraints is null || _table.UniqueConstraints.Count == 0)
            {
                <p class="text-muted small">No unique constraints found.</p>
            }
            else
            {
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr><th>Name</th><th>Clustered</th><th>Columns</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var uc in _table.UniqueConstraints)
                        {
                            <tr>
                                <td><code>@uc.Name</code></td>
                                <td><FlagBadge Value="@uc.IsClustered" /></td>
                                <td>@string.Join(", ", uc.Columns.Select(c => c.ColumnName))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

    <!-- Triggers -->
    <div class="mb-3">
        <button class="btn btn-sm btn-outline-secondary mb-2"
                @onclick="ToggleTriggers">
            @(_showTriggers ? "▲" : "▼") Triggers
            @if (_triggers is not null)
            {
                <span class="badge text-bg-secondary ms-1">@_triggers.Count</span>
            }
        </button>
        @if (_showTriggers)
        {
            @if (_triggers is null)
            {
                <div class="spinner-border spinner-border-sm ms-2"></div>
            }
            else if (_triggers.Count == 0)
            {
                <p class="text-muted small">No triggers found.</p>
            }
            else
            {
                @foreach (var trig in _triggers)
                {
                    <div class="mb-3">
                        <h6 class="d-flex align-items-center gap-2">
                            <code>[@trig.SchemaName].[@trig.TriggerName]</code>
                            <FlagBadge Value="@trig.IsActive" />
                            <a href="/servers/@ServerId/databases/@DatabaseId/tables/@TableId/triggers/@trig.SourceTriggerId"
                               class="btn btn-sm btn-outline-primary ms-auto">Full View</a>
                        </h6>
                        <SqlCodeBlock SqlBody="@trig.SqlBody" />
                    </div>
                }
            }
        }
    </div>
}

@code {
    [Parameter] public int ServerId { get; set; }
    [Parameter] public int DatabaseId { get; set; }
    [Parameter] public int? TableId { get; set; }

    private SourceTable _table = new() { IsActive = true, SchemaName = "dbo" };
    private bool _nameExists;
    private bool _isNew => TableId == null;
    private string _pasteText = string.Empty;
    private string _newColumnName = string.Empty;
    private IEnumerable<BreadcrumbItem> _breadcrumbs = [];

    // Schema section state
    private bool _showIndexes;
    private bool _showForeignKeys;
    private bool _showCheckConstraints;
    private bool _showUniqueConstraints;
    private bool _showTriggers;

    private List<SourceIndexSummary>? _indexes;
    private List<SourceForeignKeySummary>? _foreignKeys;
    private List<SourceTriggerDetail>? _triggers;

    protected override async Task OnParametersSetAsync()
    {
        var db = await Repository.GetDatabaseByIdAsync(DatabaseId);
        var databaseName = db?.DatabaseName ?? DatabaseId.ToString();
        var serverName = db?.Server.ServerName ?? ServerId.ToString();

        _breadcrumbs =
        [
            new BreadcrumbItem("Servers", "/servers"),
            new BreadcrumbItem(serverName, $"/servers/{ServerId}/databases"),
            new BreadcrumbItem(databaseName, $"/servers/{ServerId}/databases/{DatabaseId}/tables"),
            new BreadcrumbItem(_isNew ? "New Table" : "Edit Table", isActive: true)
        ];

        if (TableId.HasValue)
        {
            var existing = await Repository.GetTableByIdAsync(TableId.Value);
            if (existing is not null) _table = existing;
        }
        else
        {
            _table.DatabaseId = DatabaseId;
        }
    }

    private void AddColumn()
    {
        if (string.IsNullOrWhiteSpace(_newColumnName)) return;
        var maxSort = _table.Columns.Any() ? _table.Columns.Max(c => c.SortOrder) : 0;
        _table.Columns.Add(new SourceColumn
        {
            ColumnName = _newColumnName.Trim(),
            PersistenceType = 'R',
            SortOrder = maxSort + 10
        });
        _newColumnName = string.Empty;
    }

    private void PasteColumns()
    {
        if (string.IsNullOrWhiteSpace(_pasteText)) return;
        var maxSort = _table.Columns.Any() ? _table.Columns.Max(c => c.SortOrder) : 0;
        var names = _pasteText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var name in names)
        {
            if (string.IsNullOrEmpty(name)) continue;
            maxSort += 10;
            _table.Columns.Add(new SourceColumn
            {
                ColumnName = name,
                PersistenceType = 'R',
                SortOrder = maxSort
            });
        }
        _pasteText = string.Empty;
    }

    private void RemoveColumn(SourceColumn col)
        => _table.Columns.Remove(col);

    private async Task ToggleIndexes()
    {
        _showIndexes = !_showIndexes;
        if (_showIndexes && _indexes is null && TableId.HasValue)
            _indexes = (await Repository.GetIndexesAsync(TableId.Value)).ToList();
    }

    private async Task ToggleForeignKeys()
    {
        _showForeignKeys = !_showForeignKeys;
        if (_showForeignKeys && _foreignKeys is null && TableId.HasValue)
            _foreignKeys = (await Repository.GetForeignKeysAsync(TableId.Value)).ToList();
    }

    private async Task ToggleTriggers()
    {
        _showTriggers = !_showTriggers;
        if (_showTriggers && _triggers is null && TableId.HasValue)
            _triggers = (await Repository.GetTriggerDetailsAsync(TableId.Value)).ToList();
    }

    private async Task Save()
    {
        _nameExists = await Repository.TableNameExistsAsync(
            DatabaseId, _table.SchemaName, _table.TableName,
            _isNew ? null : TableId);
        if (_nameExists) return;

        if (_isNew)
            await Repository.AddTableAsync(_table);
        else
            await Repository.UpdateTableAsync(_table);

        Notify.Success("Table saved.");
        Nav.NavigateTo($"/servers/{ServerId}/databases/{DatabaseId}/tables");
    }
}
