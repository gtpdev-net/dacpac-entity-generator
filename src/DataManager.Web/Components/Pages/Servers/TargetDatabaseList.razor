@page "/servers/{ServerId:int}/target-databases"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject NotificationService Notify
@inject IConfiguration Configuration

<PageTitle>Destination Databases &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<BreadcrumbNav Items="@_breadcrumbs" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Destination Databases — @_serverName</h1>
    <a href="/servers/@ServerId/target-databases/new" class="btn btn-primary">Add Database</a>
</div>

@if (_databases is null)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    <PaginatedTable TItem="TargetDatabase" Items="_databases" PageSize="25">
        <HeaderTemplate>
            <th>Database Name</th>
            <th>Description</th>
            <th>Active</th>
            <th></th>
        </HeaderTemplate>
        <RowTemplate Context="db">
            <td>@db.DatabaseName</td>
            <td>@db.Description</td>
            <td><FlagBadge Value="@db.IsActive" /></td>
            <td class="text-nowrap">
                <a href="/servers/@ServerId/target-databases/@db.TargetDatabaseId/edit"
                   class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                <button class="btn btn-sm btn-outline-danger"
                        @onclick="() => Delete(db)">Delete</button>
            </td>
        </RowTemplate>
    </PaginatedTable>
}

<ConfirmDialog @ref="_confirmDialog" Title="Delete Database" ConfirmText="Delete" />

@code {
    [Parameter] public int ServerId { get; set; }

    private List<TargetDatabase>? _databases;
    private string _serverName = string.Empty;
    private IEnumerable<BreadcrumbItem> _breadcrumbs = [];
    private ConfirmDialog _confirmDialog = null!;

    protected override async Task OnParametersSetAsync()
    {
        var source = await Repository.GetServerByIdAsync(ServerId);
        _serverName = source?.ServerName ?? ServerId.ToString();

        _breadcrumbs =
        [
            new BreadcrumbItem("Servers", "/servers"),
            new BreadcrumbItem(_serverName, isActive: true)
        ];

        var dbs = await Repository.GetTargetDatabasesAsync(serverId: ServerId, includeInactive: true);
        _databases = dbs.ToList();
    }

    private async Task Delete(TargetDatabase db)
    {
        var ok = await _confirmDialog.ShowAsync(
            $"Permanently delete destination database '{db.DatabaseName}'?");
        if (!ok) return;
        await Repository.DeleteTargetDatabaseAsync(db.TargetDatabaseId);
        _databases!.Remove(db);
        Notify.Success($"Database '{db.DatabaseName}' deleted.");
    }
}
