@page "/servers"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject NavigationManager Nav
@inject NotificationService Notify
@inject IConfiguration Configuration

<PageTitle>Servers &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Servers</h1>
    <a href="/servers/new" class="btn btn-primary">Add New Server</a>
</div>

<div class="mb-3">
    <input class="form-control" style="max-width:320px" placeholder="Search by server name..."
           @bind="_search" @bind:event="oninput" />
</div>

@if (_servers is null)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    var filtered = _servers
        .Where(s => string.IsNullOrWhiteSpace(_search) || s.ServerName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .ToList();

    <PaginatedTable TItem="Server" Items="filtered" PageSize="25">
        <HeaderTemplate>
            <th>Server Name</th>
            <th>Role</th>
            <th>Connection</th>
            <th>Description</th>
            <th># Databases</th>
            <th>Active</th>
            <th>Last Modified</th>
            <th></th>
        </HeaderTemplate>
        <RowTemplate Context="src">
            <td>
                @if (src.Role == DataManager.Core.Models.Entities.ServerRole.Target)
                {
                    <a href="/servers/@src.ServerId/target-databases">@src.ServerName</a>
                }
                else
                {
                    <a href="/servers/@src.ServerId/databases">@src.ServerName</a>
                }
            </td>
            <td>
                @if (src.Role == DataManager.Core.Models.Entities.ServerRole.Target)
                {
                    <span class="badge bg-warning text-dark">Target</span>
                }
                else
                {
                    <span class="badge bg-primary">Source</span>
                }
            </td>
            <td class="text-muted small">
                @if (src.Connection is not null && !string.IsNullOrWhiteSpace(src.Connection.Hostname))
                {
                    @src.Connection.Hostname
                }
                else
                {
                    <span class="fst-italic">Not configured</span>
                }
            </td>
            <td>@src.Description</td>
            <td>
                @if (src.Role == DataManager.Core.Models.Entities.ServerRole.Target)
                {
                    @src.TargetDatabases.Count(d => d.IsActive)
                }
                else
                {
                    @src.Databases.Count(d => d.IsActive)
                }
            </td>
            <td>
                <input type="checkbox" checked="@src.IsActive"
                       @onchange="() => ToggleActive(src)" />
            </td>
            <td>@(src.ModifiedAt?.ToString("dd MMM yyyy") ?? src.CreatedAt.ToString("dd MMM yyyy"))</td>
            <td>
                <a href="/servers/@src.ServerId/edit" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                <button class="btn btn-sm btn-outline-danger"
                        @onclick="() => Delete(src)">Delete</button>
            </td>
        </RowTemplate>
    </PaginatedTable>
}

<ConfirmDialog @ref="_confirmDialog" Title="Delete Server"
               ConfirmText="Delete" />

@code {
    private List<Server>? _servers;
    private string _search = string.Empty;
    private ConfirmDialog _confirmDialog = null!;

    protected override async Task OnInitializedAsync()
    {
        var list = await Repository.GetServersAsync(includeInactive: true);
        _servers = list.ToList();
    }

    private async Task ToggleActive(Server src)
    {
        src.IsActive = !src.IsActive;
        await Repository.UpdateServerAsync(src);
        Notify.Success($"'{src.ServerName}' is now {(src.IsActive ? "active" : "inactive")}.");
    }

    private async Task Delete(Server src)
    {
        if (src.Databases.Any(d => d.IsActive))
        {
            Notify.Warning("Cannot delete a server with active databases. Deactivate it instead.");
            return;
        }
        var ok = await _confirmDialog.ShowAsync(
            $"Permanently delete server '{src.ServerName}'?");
        if (!ok) return;
        await Repository.DeleteServerAsync(src.ServerId);
        _servers!.Remove(src);
        Notify.Success($"Server '{src.ServerName}' deleted.");
    }
}
