@page "/servers/new"
@page "/servers/{ServerId:int}/edit"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject NavigationManager Nav
@inject NotificationService Notify
@inject IConfiguration Configuration

<PageTitle>@(ServerId == null ? "New Server" : "Edit Server") &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<BreadcrumbNav Items="@_breadcrumbs" />

<h2>@(ServerId == null ? "New Server" : "Edit Server")</h2>

<EditForm Model="_model" OnValidSubmit="Save" class="row g-3" style="max-width:600px;">
    <DataAnnotationsValidator />

    <div class="col-12">
        <label class="form-label">Server Name</label>
        <InputText @bind-Value="_model.ServerName" class="form-control" />
        <ValidationMessage For="() => _model.ServerName" />
        @if (_nameExists)
        {
            <div class="text-danger small">Server name already exists.</div>
        }
    </div>
    <div class="col-12">
        <label class="form-label">Description</label>
        <InputTextArea @bind-Value="_model.Description" class="form-control" rows="3" />
    </div>
    <div class="col-12">
        <label class="form-label">Role</label>
        <div class="d-flex gap-4">
            <div class="form-check">
                <input type="radio" class="form-check-input" id="roleSource"
                       checked="@(_model.Role == ServerRole.Source)"
                       @onchange="() => _model.Role = ServerRole.Source" />
                <label class="form-check-label" for="roleSource">Source</label>
            </div>
            <div class="form-check">
                <input type="radio" class="form-check-input" id="roleTarget"
                       checked="@(_model.Role == ServerRole.Target)"
                       @onchange="() => _model.Role = ServerRole.Target" />
                <label class="form-check-label" for="roleTarget">Target</label>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="form-check">
            <InputCheckbox @bind-Value="_model.IsActive" class="form-check-input" id="isActive" />
            <label class="form-check-label" for="isActive">Active</label>
        </div>
    </div>

    <div class="col-12">
        <h5 class="mt-2">Connection Details</h5>
    </div>
    <div class="col-md-8">
        <label class="form-label">Hostname</label>
        <input class="form-control" @bind="_connection.Hostname" placeholder="e.g. sqlserver.example.com" />
        @if (_hostnameRequired)
        {
            <div class="text-danger small">Hostname is required when entering connection details.</div>
        }
    </div>
    <div class="col-md-4">
        <label class="form-label">Port</label>
        <input type="number" class="form-control" @bind="_connection.Port" placeholder="1433" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Named Instance</label>
        <input class="form-control" @bind="_connection.NamedInstance" placeholder="optional" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Authentication Type</label>
        <InputSelect @bind-Value="_connection.AuthenticationType" class="form-select">
            <option value="@AuthenticationType.WindowsAuth">Windows Authentication</option>
            <option value="@AuthenticationType.SqlAuth">SQL Server Authentication</option>
            <option value="@AuthenticationType.AzureAD">Azure Active Directory</option>
        </InputSelect>
    </div>
    @if (_connection.AuthenticationType == AuthenticationType.SqlAuth)
    {
        <div class="col-12">
            <label class="form-label">Username</label>
            <input class="form-control" @bind="_connection.Username" />
        </div>
    }
    <div class="col-12">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" id="saveConnection" @bind="_saveConnection" />
            <label class="form-check-label" for="saveConnection">Save connection details</label>
        </div>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary me-2">Save</button>
        <a href="/servers" class="btn btn-secondary">Cancel</a>
    </div>

    @if (_model.ServerId > 0)
    {
        <AuditFooter CreatedBy="@_model.CreatedBy" CreatedAt="_model.CreatedAt"
                     ModifiedBy="@_model.ModifiedBy" ModifiedAt="_model.ModifiedAt" />
    }
</EditForm>

@code {
    [Parameter] public int? ServerId { get; set; }

    private Server _model = new() { IsActive = true };
    private ServerConnection _connection = new();
    private bool _saveConnection;
    private bool _nameExists;
    private bool _hostnameRequired;
    private IEnumerable<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Servers", "/servers"),
            new BreadcrumbItem(ServerId == null ? "New" : "Edit", isActive: true)
        ];

        if (ServerId.HasValue)
        {
            var existing = await Repository.GetServerByIdAsync(ServerId.Value);
            if (existing is not null)
            {
                _model = existing;
                if (existing.Connection is not null)
                {
                    _connection = existing.Connection;
                    _saveConnection = true;
                }
                else
                {
                    _connection = new ServerConnection { ServerId = existing.ServerId };
                }
            }
        }
    }

    private async Task Save()
    {
        _nameExists = await Repository.ServerNameExistsAsync(_model.ServerName, _model.ServerId == 0 ? null : _model.ServerId);
        if (_nameExists) return;

        if (_saveConnection && string.IsNullOrWhiteSpace(_connection.Hostname))
        {
            _hostnameRequired = true;
            return;
        }
        _hostnameRequired = false;

        if (_model.ServerId == 0)
            await Repository.AddServerAsync(_model);
        else
            await Repository.UpdateServerAsync(_model);

        if (_saveConnection && !string.IsNullOrWhiteSpace(_connection.Hostname))
        {
            _connection.ServerId = _model.ServerId;
            _connection.ModifiedAt = DateTime.UtcNow;
            await Repository.SaveServerConnectionAsync(_connection);
        }

        Notify.Success("Server saved.");
        Nav.NavigateTo("/servers");
    }
}
