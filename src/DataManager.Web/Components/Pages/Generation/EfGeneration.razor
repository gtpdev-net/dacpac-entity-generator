@page "/generation/ef"
@rendermode InteractiveServer
@using DataManager.Core.Models
@using DataManager.Infrastructure.Generation
@using DataManager.Core.Abstractions
@using DataManager.Infrastructure.Data
@inject BlazorGenerationLogger Logger
@inject GenerationOrchestrator Orchestrator
@inject DataManagerGenerationOrchestrator DbOrchestrator
@inject DataManagerDbSchemaDataSource DataSource
@inject IDataManagerRepository Repo
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>EF Generation &mdash; @Configuration["AppTitle"]</PageTitle>

<h1>EF Entity Generation</h1>
<p class="text-muted">
    Generate EF Core entity classes from DataManagerDb (Database-sourced) or from Excel + DACPAC files (File-sourced).
</p>

@* ── Data Source card (collapsible, contains mode tabs) ─────────────────────── *@
<div class="card mb-3">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center collapsible-header"
         @onclick="ToggleSource">
        <span>&#128209; Data Source</span>
        <span class="chevron @(_sourceCollapsed ? "" : "chevron-open")">&#8250;</span>
    </div>
    @if (!_sourceCollapsed)
    {
        <div class="card-body">
            @* ── Mode tabs ──────────────────────────────────────────────────── *@
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(_mode == GenMode.DatabaseSourced ? "active" : "")"
                            @onclick="() => SetMode(GenMode.DatabaseSourced)"
                            disabled="@_running">
                        &#128209;&nbsp;Database-sourced
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_mode == GenMode.FileSourced ? "active" : "")"
                            @onclick="() => SetMode(GenMode.FileSourced)"
                            disabled="@_running">
                        &#128196;&nbsp;File-sourced (Excel + DACPAC)
                    </button>
                </li>
            </ul>

            @if (_mode == GenMode.DatabaseSourced)
            {
                @* ── Database-sourced: source selection ─────────────────────── *@
                <div class="row g-3" style="max-width:900px">
                    <div class="col-12">
                        <label class="form-label">Select Database</label>
                        @if (_databases.Count == 0)
                        {
                            <div class="alert alert-warning mb-0">
                                No databases found in DataManagerDb. Import data first via the Import pages.
                            </div>
                        }
                        else
                        {
                            <select class="form-select font-monospace"
                                    @bind="_selectedDatabaseId"
                                    disabled="@_running">
                                <option value="-1">All Servers / Databases</option>
                                <option value="0" disabled>── or select a specific database ──</option>
                                @foreach (var db in _databases)
                                {
                                    <option value="@db.DatabaseId">
                                        [@db.ServerName].[@db.DatabaseName]&nbsp;&nbsp;(@db.SelectedForLoadCount selected for load)
                                    </option>
                                }
                            </select>
                        }
                        <div class="form-text">
                            Columns with <em>IsSelectedForLoad = true</em> and
                            <em>PersistenceType ≠ 'D'</em> are included in generation.
                        </div>
                    </div>
                </div>
            }
            else
            {
                @* ── File-sourced: input files ──────────────────────────────── *@
                <div class="row g-3" style="max-width:900px">
                    <div class="col-12">
                        <label class="form-label">Excel Mapping File</label>
                        <input type="text" class="form-control font-monospace"
                               placeholder="/full/path/to/mapping.xlsx"
                               @bind="_excelFilePath" @bind:event="oninput"
                               disabled="@_running" />
                        <div class="form-text">Full path to the .xlsx mapping file.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">DACPAC Files Folder</label>
                        <input type="text" class="form-control font-monospace"
                               placeholder="/full/path/to/dacpacs/"
                               @bind="_dacpacFolderPath" @bind:event="oninput"
                               disabled="@_running" />
                        <div class="form-text">Full path to the folder containing .dacpac files.</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── Output Locations card (collapsible, shared by both modes) ───────────────── *@
<div class="card mb-3">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center collapsible-header"
         @onclick="ToggleOutput">
        <span>&#128193;&nbsp;Output Locations</span>
        <span class="chevron @(_outputCollapsed ? "" : "chevron-open")">&#8250;</span>
    </div>
    @if (!_outputCollapsed)
    {
        <div class="card-body row g-3" style="max-width:900px">
            <div class="col-12">
                <label class="form-label fw-semibold">Solution Root</label>
                <input type="text" class="form-control font-monospace"
                       placeholder="/full/path/to/solution/root"
                       @bind="_solutionRoot" @bind:event="oninput"
                       disabled="@_running" />
                <div class="form-text">Root folder of the target solution. Output paths are computed from this and the configured suffixes in appsettings.</div>
            </div>
            <div class="col-12">
                <hr class="my-1" />
                <p class="text-muted small mb-2">Computed output paths:</p>
                <div class="row g-2">
                    <div class="col-12">
                        <span class="form-label text-muted small">SQL Entity &amp; Configuration Output Folder</span><br />
                        <span class="font-monospace @(string.IsNullOrWhiteSpace(_solutionRoot) ? "text-secondary" : "")">@(string.IsNullOrWhiteSpace(_solutionRoot) ? "(set Solution Root above)" : SqlEntityAndConfigOutputPath)</span>
                    </div>
                    <div class="col-12">
                        <span class="form-label text-muted small">SQL DbContext File</span><br />
                        <span class="font-monospace @(string.IsNullOrWhiteSpace(_solutionRoot) ? "text-secondary" : "")">@(string.IsNullOrWhiteSpace(_solutionRoot) ? "(set Solution Root above)" : SqlDbContextFilePath)</span>
                    </div>
                    <div class="col-12">
                        <span class="form-label text-muted small">SQLite Configuration Output Folder</span><br />
                        <span class="font-monospace @(string.IsNullOrWhiteSpace(_solutionRoot) ? "text-secondary" : "")">@(string.IsNullOrWhiteSpace(_solutionRoot) ? "(set Solution Root above)" : SqliteConfigOutputPath)</span>
                    </div>
                    <div class="col-12">
                        <span class="form-label text-muted small">SQLite DbContext File</span><br />
                        <span class="font-monospace @(string.IsNullOrWhiteSpace(_solutionRoot) ? "text-secondary" : "")">@(string.IsNullOrWhiteSpace(_solutionRoot) ? "(set Solution Root above)" : SqliteDbContextFilePath)</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* ── Validation errors ────────────────────────────────────────────────────── *@
@if (_validationErrors.Count > 0)
{
    <div class="alert alert-warning mb-3">
        <ul class="mb-0">
            @foreach (var err in _validationErrors)
            {
                <li>@err</li>
            }
        </ul>
    </div>
}

@* ── Generate ─────────────────────────────────────────────────────────── *@
<div class="mb-4">
    <button class="btn btn-primary btn-lg"
            @onclick="RunGeneration"
            disabled="@(!CanGenerate)">
        @if (_running)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>Generating&hellip;</span>
        }
        else
        {
            <span>&#9881; Generate</span>
        }
    </button>
    @if (_running)
    {
        <button class="btn btn-outline-danger ms-2" @onclick="Cancel">Cancel</button>
    }
</div>

@* ── Progress Log ─────────────────────────────────────────────────────── *@
@if (_logLines.Count > 0 || _running)
{
    <ProgressLog Lines="_logLines" Running="_running" OnClear="ClearLog"
                 Title="Progress Log" CardMarginClass="mb-4"
                 FillHeight="@(_sourceCollapsed && _outputCollapsed)" />
}

@* ── Result ───────────────────────────────────────────────────────────── *@
@if (_result is not null)
{
    <div class="alert @(_result.Success ? "alert-success" : "alert-danger") mb-4">
        @if (_result.Success)
        {
            <strong>Generation complete!</strong>
        }
        else
        {
            <strong>Generation finished with errors.</strong>
        }
        <div class="row g-3 mt-1">
            <div class="col-auto"><span class="badge bg-success fs-6">Entities: @_result.EntitiesGenerated</span></div>
            <div class="col-auto"><span class="badge bg-info fs-6">Views: @_result.ViewsGenerated</span></div>
            <div class="col-auto"><span class="badge bg-warning text-dark fs-6">Skipped: @_result.TablesSkipped</span></div>
            <div class="col-auto"><span class="badge bg-danger fs-6">Errors: @_result.ErrorsEncountered</span></div>
        </div>
        @if (_result.Errors.Count > 0)
        {
            <ul class="mt-2 mb-0">
                @foreach (var e in _result.Errors)
                {
                    <li>@e</li>
                }
            </ul>
        }
    </div>

    @* ── Discovery Reports ──────────────────────────────────────────── *@
    @if (_result.DiscoveryReports.Count > 0)
    {
        <h4>Discovery Reports</h4>
        <p class="text-muted small">
            Elements discovered in the DACPAC(s) that may require manual migration consideration.
        </p>
        @foreach (var report in _result.DiscoveryReports)
        {
            <DiscoveryReportPanel Report="@report" />
        }
    }
}

@code {
    // ── Generation mode ───────────────────────────────────────────────────────
    private enum GenMode { DatabaseSourced, FileSourced }
    private GenMode _mode = GenMode.DatabaseSourced;

    // ── Section collapse state ────────────────────────────────────────────────
    private bool _sourceCollapsed  = false;
    private bool _outputCollapsed  = false;

    private void ToggleSource() { if (!_running) _sourceCollapsed = !_sourceCollapsed; }
    private void ToggleOutput() { if (!_running) _outputCollapsed = !_outputCollapsed; }

    // ── Path inputs (shared + file-sourced) ───────────────────────────────────
    private string _excelFilePath    = string.Empty;
    private string _dacpacFolderPath = string.Empty;

    // ── Solution root (user-editable) + config-sourced suffixes ──────────────
    private string _solutionRoot              = string.Empty;
    private string _sqlEntityAndConfigSuffix  = string.Empty;
    private string _sqlDbContextSuffix        = string.Empty;
    private string _sqliteConfigSuffix        = string.Empty;
    private string _sqliteDbContextSuffix     = string.Empty;

    // ── Computed output paths ─────────────────────────────────────────────────
    private string SqlEntityAndConfigOutputPath => Path.Combine(_solutionRoot.Trim(), _sqlEntityAndConfigSuffix);
    private string SqlDbContextFilePath         => Path.Combine(_solutionRoot.Trim(), _sqlDbContextSuffix);
    private string SqliteConfigOutputPath       => Path.Combine(_solutionRoot.Trim(), _sqliteConfigSuffix);
    private string SqliteDbContextFilePath      => Path.Combine(_solutionRoot.Trim(), _sqliteDbContextSuffix);

    // ── Database-sourced inputs ───────────────────────────────────────────────
    private IReadOnlyList<SourceDatabaseInfo> _databases = Array.Empty<SourceDatabaseInfo>();
    private int _selectedDatabaseId = -1;

    // ── Run state ─────────────────────────────────────────────────────────────
    private bool _running;
    private CancellationTokenSource? _cts;
    private GenerationResult? _result;
    private readonly List<ProgressLog.LogEntry> _logLines        = new();
    private readonly List<string>                _validationErrors = new();

    // ── Temp directory ────────────────────────────────────────────────────────
    private string? _tempDir;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        Logger.OnLog += HandleLog;
        _databases = await Repo.GetInScopeDatabasesAsync();

        _solutionRoot             = Configuration["GenerationPaths:SolutionRoot"] ?? string.Empty;
        _sqlEntityAndConfigSuffix = Configuration["GenerationPaths:SqlEntityAndConfigOutputDir"] ?? string.Empty;
        _sqlDbContextSuffix       = Configuration["GenerationPaths:SqlDbContextFilePath"] ?? string.Empty;
        _sqliteConfigSuffix       = Configuration["GenerationPaths:SqliteConfigOutputDir"] ?? string.Empty;
        _sqliteDbContextSuffix    = Configuration["GenerationPaths:SqliteDbContextFilePath"] ?? string.Empty;
    }

    // ── Mode toggle ───────────────────────────────────────────────────────────
    private void SetMode(GenMode mode)
    {
        if (!_running) _mode = mode;
    }

    // ── CanGenerate ───────────────────────────────────────────────────────────
    private bool CanGenerate => !_running && !string.IsNullOrWhiteSpace(_solutionRoot) && (
        _mode == GenMode.DatabaseSourced
            ? _selectedDatabaseId != 0
            : !string.IsNullOrWhiteSpace(_excelFilePath)
              && !string.IsNullOrWhiteSpace(_dacpacFolderPath));

    // ── Generation dispatch ───────────────────────────────────────────────────
    private async Task RunGeneration()
    {
        if (!CanGenerate) return;

        // Validation
        _validationErrors.Clear();
        if (_mode == GenMode.FileSourced)
        {
            if (!File.Exists(_excelFilePath.Trim()))
                _validationErrors.Add($"Excel file not found: {_excelFilePath.Trim()}");
            if (!Directory.Exists(_dacpacFolderPath.Trim()))
                _validationErrors.Add($"DACPAC folder not found: {_dacpacFolderPath.Trim()}");
        }
        if (!Directory.Exists(SqlEntityAndConfigOutputPath))
            _validationErrors.Add($"SQL entity/config output folder not found: {SqlEntityAndConfigOutputPath}");
        if (!Directory.Exists(SqliteConfigOutputPath))
            _validationErrors.Add($"SQLite config output folder not found: {SqliteConfigOutputPath}");

        if (_validationErrors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        _result          = null;
        _logLines.Clear();
        _sourceCollapsed = true;
        _outputCollapsed = true;
        _running         = true;
        _cts             = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            if (_mode == GenMode.DatabaseSourced)
                await RunDatabaseSourcedAsync();
            else
                await RunFileSourcedAsync();
        }
        catch (OperationCanceledException)
        {
            _logLines.Add(new ProgressLog.LogEntry("warning", "Generation cancelled."));
        }
        catch (Exception ex)
        {
            _logLines.Add(new ProgressLog.LogEntry("error", $"Unexpected error: {ex.Message}"));
        }
        finally
        {
            _running = false;
            CleanupTemp();
            StateHasChanged();
        }
    }

    // ── Database-sourced pipeline ─────────────────────────────────────────────
    private async Task RunDatabaseSourcedAsync()
    {
        DataSource.DatabaseId = _selectedDatabaseId;

        _result = await DbOrchestrator.RunAsync(
            DataSource,
            SqlEntityAndConfigOutputPath,
            SqlDbContextFilePath,
            SqliteConfigOutputPath,
            SqliteDbContextFilePath);
    }

    // ── File-sourced pipeline ─────────────────────────────────────────────────
    private async Task RunFileSourcedAsync()
    {
        var excelPath    = _excelFilePath.Trim();
        var dacpacFolder = _dacpacFolderPath.Trim();

        _tempDir = Path.Combine(Path.GetTempPath(), "efgen_" + Guid.NewGuid().ToString("N"));
        var tempInput = Path.Combine(_tempDir, "_input");
        Directory.CreateDirectory(tempInput);

        File.Copy(excelPath, Path.Combine(tempInput, Path.GetFileName(excelPath)), overwrite: true);

        var tempDacpacs = Path.Combine(tempInput, "dacpacs");
        Directory.CreateDirectory(tempDacpacs);
        foreach (var dacpac in Directory.EnumerateFiles(dacpacFolder, "*.dacpac", SearchOption.TopDirectoryOnly))
            File.Copy(dacpac, Path.Combine(tempDacpacs, Path.GetFileName(dacpac)), overwrite: true);

        _result = await Task.Run(() => Orchestrator.Run(
            tempInput,
            SqlEntityAndConfigOutputPath,
            SqlDbContextFilePath,
            SqliteConfigOutputPath,
            SqliteDbContextFilePath));
    }

    private void Cancel() => _cts?.Cancel();

    private void CleanupTemp()
    {
        if (_tempDir is not null && Directory.Exists(_tempDir))
        {
            try { Directory.Delete(_tempDir, recursive: true); } catch { /* best-effort */ }
            _tempDir = null;
        }
    }

    // ── Logger callback ───────────────────────────────────────────────────────
    private void HandleLog(string level, string message)
    {
        InvokeAsync(() =>
        {
            _logLines.Add(new ProgressLog.LogEntry(level, message));
            StateHasChanged();
        });
    }

    // ── UI helpers ────────────────────────────────────────────────────────────
    private void ClearLog() => _logLines.Clear();

    // ── Cleanup ───────────────────────────────────────────────────────────────
    public void Dispose()
    {
        Logger.OnLog -= HandleLog;
        _cts?.Cancel();
        CleanupTemp();
    }
}
