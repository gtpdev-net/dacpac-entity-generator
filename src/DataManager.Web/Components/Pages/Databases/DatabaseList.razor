@page "/servers/{ServerId:int}/databases"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject NotificationService Notify
@inject IConfiguration Configuration

<PageTitle>Databases &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<BreadcrumbNav Items="@_breadcrumbs" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Databases — @_serverName</h1>
    <a href="/servers/@ServerId/databases/new" class="btn btn-primary">Add Database</a>
</div>

@if (_databases is null)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    <PaginatedTable TItem="SourceDatabaseInfo" Items="_databases" PageSize="25">
        <HeaderTemplate>
            <th>Database Name</th>
            <th>Description</th>
            <th># Tables</th>
            <th># In-Scope</th>
            <th># For Load</th>
            <th>Active</th>
            <th></th>
        </HeaderTemplate>
        <RowTemplate Context="db">
            <td><a href="/servers/@ServerId/databases/@db.DatabaseId/tables">@db.DatabaseName</a></td>
            <td>@db.Description</td>
            <td>@db.TableCount</td>
            <td>@db.InScopeColumnCount</td>
            <td>@db.SelectedForLoadCount</td>
            <td><FlagBadge Value="@db.IsActive" /></td>
            <td class="text-nowrap">
                <a href="/servers/@ServerId/databases/@db.DatabaseId/schema"
                   class="btn btn-sm btn-outline-info me-1">Schema</a>
                <a href="/servers/@ServerId/databases/@db.DatabaseId/edit"
                   class="btn btn-sm btn-outline-secondary">Edit</a>
            </td>
        </RowTemplate>
    </PaginatedTable>
}

@code {
    [Parameter] public int ServerId { get; set; }

    private List<SourceDatabaseInfo>? _databases;
    private string _serverName = string.Empty;
    private IEnumerable<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync()
    {
        var source = await Repository.GetServerByIdAsync(ServerId);
        _serverName = source?.ServerName ?? ServerId.ToString();

        _breadcrumbs =
        [
            new BreadcrumbItem("Servers", "/servers"),
            new BreadcrumbItem(_serverName, isActive: true)
        ];

        var dbs = await Repository.GetInScopeDatabasesAsync(serverId: ServerId, includeInactive: true);
        _databases = dbs.ToList();
    }
}
