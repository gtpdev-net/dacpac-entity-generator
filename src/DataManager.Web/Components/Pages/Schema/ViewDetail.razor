@page "/servers/{SourceId:int}/databases/{DatabaseId:int}/schema/views/{ViewId:int}"
@rendermode InteractiveServer
@inject IDataManagerRepository Repository
@inject IConfiguration Configuration

<PageTitle>View Detail &mdash; @Configuration["AppTitle"] Migration</PageTitle>

<BreadcrumbNav Items="@_breadcrumbs" />

@if (_loading)
{
    <div class="spinner-border" role="status"><span class="visually-hidden">Loading…</span></div>
}
else if (_view is null)
{
    <div class="alert alert-warning">View not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">
            <span class="text-muted fw-normal">[@_view.SchemaName].</span>[@_view.ViewName]
        </h1>
        <span class="badge @(_view.IsActive ? "text-bg-success" : "text-bg-secondary") fs-6">
            @(_view.IsActive ? "Active" : "Inactive")
        </span>
    </div>

    @if (_view.HasStandardAuditColumns)
    {
        <div class="alert alert-info py-2 mb-3">
            <span class="me-2">&#9989;</span>Has standard audit columns (CreatedAt, ModifiedAt, CreatedBy, ModifiedBy).
        </div>
    }

    <!-- Columns -->
    <h4 class="mt-3">
        Columns
        <span class="badge text-bg-secondary ms-2">@_view.Columns.Count</span>
    </h4>

    @if (_view.Columns.Count == 0)
    {
        <p class="text-muted">No column metadata available.</p>
    }
    else
    {
        <table class="table table-sm table-bordered table-hover align-middle mb-4">
            <thead class="table-light">
                <tr>
                    <th class="text-end" style="width:60px">#</th>
                    <th>Column Name</th>
                    <th>SQL Type</th>
                    <th style="width:80px">Nullable</th>
                    <th class="text-end" style="width:90px">Max Len</th>
                    <th class="text-end" style="width:80px">Precision</th>
                    <th class="text-end" style="width:70px">Scale</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var col in _view.Columns.OrderBy(c => c.OrdinalPosition))
                {
                    <tr>
                        <td class="text-end text-muted">@col.OrdinalPosition</td>
                        <td><code>@col.ColumnName</code></td>
                        <td>@col.SqlType</td>
                        <td><FlagBadge Value="@col.IsNullable" /></td>
                        <td class="text-end">@col.MaxLength</td>
                        <td class="text-end">@col.Precision</td>
                        <td class="text-end">@col.Scale</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- SQL Body -->
    <h4>SQL Body</h4>
    <SqlCodeBlock SqlBody="@_view.SqlBody" />
}

@code {
    [Parameter] public int SourceId { get; set; }
    [Parameter] public int DatabaseId { get; set; }
    [Parameter] public int ViewId { get; set; }

    private bool _loading = true;
    private SourceViewDetail? _view;
    private string _databaseName = string.Empty;
    private string _serverName = string.Empty;
    private IEnumerable<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var db = await Repository.GetDatabaseByIdAsync(DatabaseId);
        _databaseName = db?.DatabaseName ?? DatabaseId.ToString();
        _serverName = db?.Source.ServerName ?? SourceId.ToString();

        _view = await Repository.GetViewByIdAsync(ViewId);

        _breadcrumbs =
        [
            new BreadcrumbItem("Servers", "/servers"),
            new BreadcrumbItem(_serverName, $"/servers/{SourceId}/databases"),
            new BreadcrumbItem(_databaseName, $"/servers/{SourceId}/databases/{DatabaseId}/tables"),
            new BreadcrumbItem("Schema", $"/servers/{SourceId}/databases/{DatabaseId}/schema"),
            new BreadcrumbItem(_view is null ? "View" : $"{_view.SchemaName}.{_view.ViewName}", isActive: true)
        ];

        _loading = false;
    }
}
