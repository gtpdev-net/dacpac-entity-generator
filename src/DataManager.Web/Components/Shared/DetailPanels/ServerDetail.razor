@inject IDataManagerRepository Repository

@if (_loading)
{
    <div class="spinner-border spinner-border-sm" role="status"></div>
}
else if (_source is null)
{
    <div class="alert alert-warning">Server not found.</div>
}
else
{
    <h5 class="d-flex justify-content-between align-items-center mb-3">
        🖥️ @_source.ServerName
        <span class="badge @(_source.IsActive ? "text-bg-success" : "text-bg-secondary") fs-6">
            @(_source.IsActive ? "Active" : "Inactive")
        </span>
    </h5>

    @if (!string.IsNullOrWhiteSpace(_source.Description))
    {
        <p class="text-muted small">@_source.Description</p>
    }

    <table class="table table-sm table-borderless mb-3">
        <tbody>
            <tr><th class="text-muted fw-normal" style="width:140px">Databases</th><td>@_dbCount</td></tr>
            <tr><th class="text-muted fw-normal">Created</th><td>@_source.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</td></tr>
            @if (_source.ModifiedAt.HasValue)
            {
                <tr><th class="text-muted fw-normal">Modified</th><td>@_source.ModifiedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</td></tr>
            }
        </tbody>
    </table>

    <a class="btn btn-sm btn-outline-primary" href="/servers/@EntityId/databases">Open Full Page →</a>
}

@code {
    [Parameter, EditorRequired] public int EntityId { get; set; }

    private bool _loading = true;
    private Source? _source;
    private int _dbCount;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _source = await Repository.GetSourceByIdAsync(EntityId);
        var dbs = await Repository.GetInScopeDatabasesAsync(EntityId, includeInactive: true);
        _dbCount = dbs.Count;
        _loading = false;
    }
}
