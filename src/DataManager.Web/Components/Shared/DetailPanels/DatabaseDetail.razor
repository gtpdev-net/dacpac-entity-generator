@inject IDataManagerRepository Repository

@if (_loading)
{
    <div class="spinner-border spinner-border-sm" role="status"></div>
}
else if (_db is null)
{
    <div class="alert alert-warning">Database not found.</div>
}
else
{
    <h5 class="d-flex justify-content-between align-items-center mb-3">
        🗄️ @_db.DatabaseName
        <span class="badge @(_db.IsActive ? "text-bg-success" : "text-bg-secondary") fs-6">
            @(_db.IsActive ? "Active" : "Inactive")
        </span>
    </h5>

    @if (!string.IsNullOrWhiteSpace(_db.Description))
    {
        <p class="text-muted small">@_db.Description</p>
    }

    <table class="table table-sm table-borderless mb-3">
        <tbody>
            <tr><th class="text-muted fw-normal" style="width:160px">Server</th><td>@_db.Server.ServerName</td></tr>
            <tr><th class="text-muted fw-normal">Tables</th><td>@_tableCount</td></tr>
            <tr><th class="text-muted fw-normal">Created</th><td>@_db.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</td></tr>
            @if (_db.LastImportedAt.HasValue)
            {
                <tr><th class="text-muted fw-normal">Last Import</th><td>@_db.LastImportedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</td></tr>
            }
            @if (!string.IsNullOrWhiteSpace(_db.LastImportedModelHash))
            {
                <tr><th class="text-muted fw-normal">Import Hash</th><td><code class="small">@_db.LastImportedModelHash[..12]…</code></td></tr>
            }
        </tbody>
    </table>

    <a class="btn btn-sm btn-outline-primary" href="/servers/@_db.ServerId/databases/@EntityId/tables">Open Full Page →</a>
}

@code {
    [Parameter, EditorRequired] public int EntityId { get; set; }

    private bool _loading = true;
    private SourceDatabase? _db;
    private int _tableCount;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _db = await Repository.GetDatabaseByIdAsync(EntityId);
        var tables = await Repository.GetInScopeTablesAsync(EntityId, includeInactive: true);
        _tableCount = tables.Count;
        _loading = false;
    }
}
