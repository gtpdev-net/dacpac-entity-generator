@inject IDataManagerRepository Repository

@if (_loading)
{
    <div class="spinner-border spinner-border-sm" role="status"></div>
}
else if (_error is not null)
{
    <div class="alert alert-warning">@_error</div>
}
else if (_index is null)
{
    <div class="alert alert-warning">Index not found.</div>
}
else
{
    <h5 class="mb-3">Index: @_index.Name</h5>

    <div class="mb-2">
        @if (_index.IsPrimaryKeyIndex) { <span class="badge text-bg-warning me-1">Primary Key</span> }
        @if (_index.IsUnique) { <span class="badge text-bg-primary me-1">Unique</span> }
        @if (_index.IsClustered) { <span class="badge text-bg-secondary me-1">Clustered</span> }
    </div>

    @if (!string.IsNullOrWhiteSpace(_index.FilterDefinition))
    {
        <div class="mb-2">
            <span class="text-muted small">Filter: </span><code>@_index.FilterDefinition</code>
        </div>
    }

    <h6>Columns</h6>
    <ul class="list-group list-group-flush mb-3">
        @foreach (var col in _index.Columns)
        {
            <li class="list-group-item py-1 ps-0"><code>@col</code></li>
        }
    </ul>
}

@code {
    [Parameter, EditorRequired] public TreeNode Node { get; set; } = null!;

    private bool _loading = true;
    private SourceIndexSummary? _index;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _index = null;

        var tableId = ExtractSegmentId(Node.Id, "table-");
        if (tableId is null)
        {
            _error = "Could not determine parent table.";
            _loading = false;
            return;
        }

        var indexes = await Repository.GetIndexesAsync(tableId.Value);
        _index = indexes.FirstOrDefault(i => i.SourceIndexId == Node.EntityId);
        _loading = false;
    }

    private static int? ExtractSegmentId(string nodeId, string prefix)
    {
        foreach (var seg in nodeId.Split('/'))
            if (seg.StartsWith(prefix) && int.TryParse(seg[prefix.Length..], out int id))
                return id;
        return null;
    }
}
